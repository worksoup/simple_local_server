[Unit]
Description=Simple local server: Tieba sign daemon & tracker merger
After=network.target
Wants=network.target

[Service]
Type=simple
DynamicUser=yes
ExecStartPre=/bin/sh -c 'if [ ! -f /var/lib/sl-server/sl-server.toml ]; then install -m 640 /etc/sl-server/sl-server.toml.example /var/lib/sl-server/sl-server.toml; fi'
ExecStart=/usr/bin/simple_local_server -c /var/lib/sl-server/sl-server.toml

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/sl-server
StateDirectory=sl-server

StandardOutput=journal
StandardError=journal
SyslogIdentifier=simple-local-server

LimitNOFILE=65536
LimitNPROC=4096

[Install]
WantedBy=multi-user.target
